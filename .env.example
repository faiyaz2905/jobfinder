# Browser-safe Supabase Auth settings. These are intentionally public and are
# protected by Row Level Security plus the server-side email allowlist.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only Supabase settings.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Server-only access controls.
ALLOWED_USER_EMAILS=you@example.com,second-recipient@example.com
APP_ORIGIN=https://YOUR_PROJECT.vercel.app
CRON_SECRET=GENERATE_A_RANDOM_VALUE_OF_AT_LEAST_32_CHARACTERS

# Server-only Gmail SMTP settings. Use a newly generated App Password.
RADAR_SMTP_HOST=smtp.gmail.com
RADAR_SMTP_PORT=587
RADAR_SMTP_TLS=1
RADAR_SMTP_USERNAME=YOUR_GMAIL_ADDRESS
RADAR_SMTP_PASSWORD=YOUR_NEW_GMAIL_APP_PASSWORD
RADAR_EMAIL_FROM=YOUR_GMAIL_ADDRESS
RADAR_EMAIL_TO=you@example.com,second-recipient@example.com

# Optional scan settings and discovery providers.
RADAR_SCAN_TIMEOUT=12
RADAR_SCAN_WORKERS=6
SERPAPI_API_KEY=
META_ACCESS_TOKEN=
