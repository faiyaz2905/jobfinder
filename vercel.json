{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd radar-dashboard && npm install",
  "buildCommand": "cd radar-dashboard && npm run build",
  "outputDirectory": "radar-dashboard/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 300,
      "includeFiles": "radar/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py?route=:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://*.supabase.co; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
